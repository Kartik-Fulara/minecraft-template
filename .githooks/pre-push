#!/usr/bin/env bash
# =============================================================================
# .githooks/pre-push
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
NC='\033[0m'

VERSION=$(tr -d '[:space:]' < VERSION 2>/dev/null || true)
[[ -z "$VERSION" ]] && { echo -e "${RED}✖ VERSION file is empty or missing.${NC}"; exit 1; }

POM_VER=$(grep -m1 '<version>' pom.xml 2>/dev/null | sed 's/.*<version>\(.*\)<\/version>.*/\1/' | tr -d '[:space:]' || true)
[[ -n "$POM_VER" && "$POM_VER" != "$VERSION" ]] && { echo -e "${RED}✖ pom.xml version != VERSION.${NC}"; exit 1; }

echo "Running Maven compile check..."
if command -v mvn &>/dev/null; then
  mvn --batch-mode compile -q || { echo -e "${RED}✖ Maven compile failed.${NC}"; exit 1; }
fi

exit 0
